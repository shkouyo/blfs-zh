<sect1 id="breeze-icons" xreflabel="breeze-icons-&kf6-version;">
  <?dbhtml filename="breeze-icons.html"?>


  <title>breeze-icons-&kf6-version;</title>

  <indexterm zone="breeze-icons">
    <primary sortas="a-breeze-icons">breeze-icons</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to Breeze Icons</title>

    <para>
      The <application>Breeze Icons</application> package contains the
      default icons for <application>KDE Plasma</application> applications,
      but it can be used for other window environments.
    </para>

    &lfs130_checked;

    <bridgehead renderas="sect3">Package Information</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          下载地址（HTTP）：<ulink url="&breeze-icons-download-http;"/>
        </para>
      </listitem>
      <listitem>
        <para>
          下载地址（FTP）：<ulink url="&breeze-icons-download-ftp;"/>
        </para>
      </listitem>
      <listitem>
        <para>
          MD5 校验和：&breeze-icons-md5sum;
        </para>
      </listitem>
      <listitem>
        <para>
          大小：&breeze-icons-size;
        </para>
      </listitem>
      <listitem>
        <para>
          预计所需磁盘空间：&breeze-icons-buildsize;
        </para>
      </listitem>
      <listitem>
        <para>
          预计构建时间：&breeze-icons-time;
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Breeze Icons Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <xref linkend="extra-cmake-modules"/> and
      <xref linkend="qt6"/>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <xref linkend="kf6-frameworks"/>,
      <xref linkend="libxml2"/>, and
      <xref linkend="lxml"/>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of Breeze Icons</title>

    <para>
      Install <application>Breeze Icons</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr \
      -D BUILD_TESTING=OFF         \
      -D WITH_ICON_GENERATION=OFF  \
      -W no-dev ..                 &amp;&amp;
make</userinput></screen>

    <para>
      This package does not come with a test suite.
    </para>

    <para>
      Now, as the <systemitem class="username">root</systemitem> user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    <para>
      <parameter>-D BUILD_TESTING=OFF</parameter>: This parameter disables
      building the testing framework, which requires some modules from
      <xref linkend="kf6-frameworks"/>.
    </para>

    <para>
      <parameter>-D WITH_ICON_GENERATION=OFF</parameter>: This parameter
      disables generation of 24x24 dark icons, which requires the
      <xref linkend="lxml"/> python module. This parameter can be removed
      if <xref linkend="lxml"/> is installed.
    </para>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Library</segtitle>
