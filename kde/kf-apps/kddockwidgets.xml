<sect1 id="kddockwidgets" xreflabel="KDDockWidgets-&kddockwidgets-version;">
  <?dbhtml filename="kddockwidgets.html"?>

  <title>KDDockWidgets-&kddockwidgets-version;</title>

  <indexterm zone="kddockwidgets">
    <primary sortas="a-KDDockWidgets">KDDockWidgets</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to KDDockWidgets</title>

    <para>
      The <application>KDDockWidgets</application> package provides Qt dock
      widgets that are suitable for replacing QDockWidget and implementing
      advanced functionality that is missing from Qt.
    </para>

    &lfs130_checked;

    <bridgehead renderas="sect3">Package Information</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
