<sect1 id="imath" xreflabel="Imath-&Imath-version;">
  <?dbhtml filename="imath.html"?>

  <title>Imath-&Imath-version;</title>

  <indexterm zone="imath">
    <primary sortas="a-Imath-&Imath-version;">Imath</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to Imath</title>

    <para>
      <application>Imath</application> is a C++ and python library of 2D 
      and 3D vector, matrix, and math operations for computer graphics.
    </para>

    &lfs130_checked;

    <bridgehead renderas="sect3">Package Information</bridgehead>
    <itemizedlist spacing="compact">
