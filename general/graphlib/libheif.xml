      <xref linkend='gdk-pixbuf'/>,
      <xref linkend='libjpeg'/>,
      <xref linkend='libpng'/>,
      <xref linkend='libtiff'/>,
      <xref linkend='libwebp'/>,
      <xref linkend='openjpeg2'/>,
      <xref linkend='sdl2'/>,
