  <!--Required section-->
  <sect2 role="package">
    <title>Introduction to libheif</title>

    <para>
      The <application>libheif</application> package is an HEIF and AVIF
      file format decoder and encoder.
    </para>

    &lfs130_checked;

    <bridgehead renderas="sect3">Package Information</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&libheif-download-http;"/>
        </para>
      </listitem>
      <listitem>
        <para>
          Download MD5 sum: &libheif-md5sum;
        </para>
      </listitem>
      <listitem>
        <para>
          Download size: &libheif-size;
        </para>
      </listitem>
      <listitem>
        <para>
          Estimated disk space required: &libheif-buildsize;
        </para>
      </listitem>
      <listitem>
        <para>
          Estimated build time: &libheif-time;
        </para>
