  <sect2 role="installation">
    <title>Installation of libheif</title>

<!--
    <para>
      First, fix building libheif if you are going to enable the SVT-AV1
      encoder:
    </para>

<screen><userinput remap="pre">patch -Np1 -i ../libheif-&libheif-version;-svt_av1_build_fix-2.patch</userinput></screen>
-->

    <para>
      Install <application>libheif</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr \
      -D CMAKE_BUILD_TYPE=Release  \
      -D WITH_GDK_PIXBUF=OFF       \
      -D WITH_OpenH264_DECODER=OFF \
      -G Ninja ..                  &amp;&amp;
ninja</userinput></screen>

    <para>
      To test the results, issue: <command>ninja test</command>.
    </para>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install</userinput></screen>
  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    <para>
      <parameter>-D WITH_GDK_PIXBUF=OFF</parameter>: This option disables
      building the gdk-pixbuf loader, as <xref linkend='gdk-pixbuf'/> is
      supposed to use this package via <xref linkend='glycin'/> instead of
      the loader.
    </para>

    <!-- The intention is only listing an option if the dependency is
         in BLFS and it's not enabled by default even if the dependency is
         installed.  -->

    <para>
      <option>-D WITH_DAV1D=ON</option>: This option allows using
      <xref linkend='dav1d'/> to decode AV1 data in AVIF files.
    </para>

    <para>
      <option>-D WITH_FFMPEG_DECODER=ON</option>: This option allows using
      <xref linkend='ffmpeg'/> to decode H.265 data in HEIC files.
    </para>

    <para>
      <option>-D WITH_JPEG_ENCODER=ON -D WITH_JPEG_DECODER=ON</option>: These
      options allow using <xref linkend='libjpeg'/> to encode and decode
      HEIF files with JPEG data.
    </para>

    <para>
      <option>-D WITH_OpenJPEG_ENCODER=ON -D WITH_OpenJPEG_DECODER=ON</option>:
      These options allow using <xref linkend='openjpeg2'/> to encode and
      decode HEIF files with JPEG 2000 data.
    </para>

    <para>
      <option>-D WITH_SvtEnc=ON</option>: This option allows using
      <xref linkend='svt-av1'/> to encode AV1 data for AVIF files.
    </para>
  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Library</segtitle>
      <segtitle>Installed Directory</segtitle>

      <seglistitem>
        <seg>
          heif-convert (symlink to heif-dec), heif-dec, heif-enc, heif-info,
          heif-thumbnailer (if libpng is available), and heif-view (if SDL2
          is available)
        </seg>
        <seg>
          libheif.so
        </seg>
        <seg>
          /usr/include/libheif, /usr/lib/libheif, and
          /usr/lib/cmake/libheif
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

      <varlistentry id="heif-dec">
        <term><command>heif-dec</command></term>
        <listitem>
          <para>
            decodes a HEIC/HEIF image
          </para>
          <indexterm zone="libheif heif-dec">
            <primary sortas="b-heif-dec">heif-dec</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="heif-enc">
        <term><command>heif-enc</command></term>
        <listitem>
          <para>
            converts an image to HEIC/HEIF
          </para>
          <indexterm zone="libheif heif-enc">
            <primary sortas="b-heif-enc">heif-enc</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="heif-info">
        <term><command>heif-info</command></term>
        <listitem>
          <para>
            shows information about a HEIC/HEIF file
          </para>
          <indexterm zone="libheif heif-info">
            <primary sortas="b-heif-info">heif-info</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="heif-thumbnailer">
        <term><command>heif-thumbnailer</command></term>
        <listitem>
          <para>
            creates thumbnails from HEIC/HEIF files
          </para>
          <indexterm zone="libheif heif-thumbnailer">
            <primary sortas="b-heif-thumbnailer">heif-thumbnailer</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="heif-view">
        <term><command>heif-view</command></term>
        <listitem>
          <para>
            displays an image in HEIC/HEIF format with SDL2
          </para>
          <indexterm zone="libheif heif-view">
            <primary sortas="b-heif-view">heif-view</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="libheif-lib">
        <term><filename class="libraryfile">libheif.so</filename></term>
        <listitem>
          <para>
            is an ISO/IEC 23008-12:2017 HEIF and AVIF (AV1 Image File
            Format) file format decoder and encoder
          </para>
          <indexterm zone="libheif libheif-lib">
            <primary sortas="c-libheif">libheif.so</primary>
          </indexterm>
        </listitem>
      </varlistentry>
    </variablelist>
  </sect2>
