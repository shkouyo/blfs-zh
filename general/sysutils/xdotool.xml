    <bridgehead renderas="sect3">xdotool Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <xref linkend="xorg7-lib"/>
    </para>

    <bridgehead renderas="sect4">Optional (required for tests)</bridgehead>
    <para role="optional">
      <xref linkend="gnome-session"/>,
      <xref linkend="openbox"/>,
      <xref linkend="ruby"/>,
      <xref linkend="xorg7-app"/>, and
      <xref linkend="xorg-server"/> (for the <command>Xvfb</command> program),
