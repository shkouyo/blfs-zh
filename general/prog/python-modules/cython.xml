  <sect2 id="cython" xreflabel="cython-&cython-version;">

    <title>Cython-&cython-version;</title>

    <indexterm zone="cython">
      <primary sortas="a-cython">cython</primary>
    </indexterm>

    <sect3 role="package">
      <title>Introduction to Cython Module</title>

      <para>
        The <application>Cython</application> package provides a
        compiler for writing C extensions for the Python language.
      </para>

      &lfs130_checked;

      <bridgehead renderas="sect4">Package Information</bridgehead>
      <itemizedlist spacing="compact">
        <listitem>
          <para>
            下载地址（HTTP）：<ulink url="&cython-download-http;"/>
          </para>
        </listitem>
        <listitem>
          <para>
            下载地址（FTP）：<ulink url="&cython-download-ftp;"/>
          </para>
        </listitem>
        <listitem>
          <para>
            MD5 校验和：&cython-md5sum;
          </para>
        </listitem>
        <listitem>
          <para>
            大小：&cython-size;
          </para>
        </listitem>
        <listitem>
          <para>
            预计所需磁盘空间：&cython-buildsize;
          </para>
        </listitem>
        <listitem>
          <para>
            预计构建时间：&cython-time;
          </para>
        </listitem>
      </itemizedlist>

      <bridgehead renderas="sect3">Cython Dependencies</bridgehead>

      <bridgehead renderas="sect4">Optional (for tests)</bridgehead>
      <para role="optional">
        <xref linkend="gdb"/> and
        <xref linkend="pytest"/>
      </para>
    </sect3>

    <sect3 role="installation">
      <title>Installation of Cython</title>

      <para>
        Build the module:
      </para>

&build-wheel;

      <para>
        Now, as the <systemitem class="username">root</systemitem> user:
      </para>

<screen role="root"><userinput>&install-wheel; Cython</userinput></screen>

      <para>
        This package does come with a test suite, but running it takes a long
        time (almost 60 SBUs). The test suite will print data to the screen
        though to note to the user that it is still running. To run the tests,
        issue: <command>python3 runtests.py</command>. In the test log, look
        for lines starting with <emphasis role='strong'>Ran</emphasis> and
        the following lines. A few failures are expected, specially in gdb
        tests.
      </para>

    </sect3>

    <xi:include xmlns:xi="http://www.w3.org/2001/XInclude"
      href="../../../xincludes/pip3-cmd-explain.xml"/>

    <sect3 role="content">
      <title>Contents</title>

      <segmentedlist>
        <segtitle>Installed Programs</segtitle>
        <segtitle>Installed Libraries</segtitle>
        <segtitle>Installed Directories</segtitle>

        <seglistitem>
          <seg>
            cygdb,
            cython, and
            cythonize
          </seg>
          <seg>None</seg>
          <seg>
            /usr/lib/python&python3-majorver;/site-packages/Cython,
            /usr/lib/python&python3-majorver;/site-packages/Cython-&cython-version;.dist-info, and
            /usr/lib/python&python3-majorver;/site-packages/pyximport
          </seg>
        </seglistitem>
      </segmentedlist>

      <variablelist>
        <bridgehead renderas="sect5">Short Descriptions</bridgehead>
        <?dbfo list-presentation="list"?>
        <?dbhtml list-presentation="table"?>

        <varlistentry id="cygdb">
          <term><command>cygdb</command></term>
          <listitem>
            <para>
              is the Cython debugger
            </para>
            <indexterm zone="cython cygdb">
              <primary sortas="b-cygdb">cygdb</primary>
            </indexterm>
          </listitem>
        </varlistentry>

        <varlistentry id="cython-prog">
          <term><command>cython</command></term>
          <listitem>
            <para>
              is a compiler for code written in the Cython language. It outputs
              a C/C++ program which can be compiled with a C/C++ compiler
            </para>
            <indexterm zone="cython cython-prog">
              <primary sortas="b-cython-prog">cython</primary>
            </indexterm>
          </listitem>
        </varlistentry>

        <varlistentry id="cythonize">
          <term><command>cythonize</command></term>
          <listitem>
            <para>
              is a compiler for code written in the Cython language. It outputs
              an extension module which is directly importable from Python
            </para>
            <indexterm zone="cython cythonize">
              <primary sortas="b-cythonize">cythonize</primary>
            </indexterm>
          </listitem>
        </varlistentry>

      </variablelist>

    </sect3>

