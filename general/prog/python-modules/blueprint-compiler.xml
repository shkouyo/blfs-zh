      <bridgehead renderas="sect4">blueprint-compiler Dependencies</bridgehead>

      <bridgehead renderas="sect5">Required</bridgehead>
      <para role="required">
        <xref linkend="pygobject3"/>
      </para>

      <bridgehead renderas="sect5">Optional (required to run the tests)</bridgehead>
      <para role="optional">
        <xref linkend="gtk4"/>
      </para>

      <bridgehead renderas="sect5">Optional (required to build the documentation)</bridgehead>
      <para role="optional">
        <xref linkend="sphinx"/>
      </para>

    </sect3>

    <sect3 role="installation">
      <title>Installation of blueprint-compiler</title>

      <para>
        Install <application>blueprint-compiler</application> by running the
        following commands:
      </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

meson setup --prefix=/usr --buildtype=release .. &amp;&amp;
ninja</userinput></screen>

      <para>
        To run the tests issue: <command>ninja test</command>. The tests need
        to be run in a graphical environment, and you must have
        <xref linkend="gtk4"/> installed.
      </para>

      <para>
        Now, as the &root; user:
      </para>

<screen role="root"><userinput>ninja install</userinput></screen>

    </sect3>

    <sect3 role="commands">
      <title>Command Explanations</title>
      
      <para>
        <option>-D docs=true</option>: Use this option if you have
        <xref linkend="sphinx"/> installed and you want to build the
        documentation.
      </para>
    </sect3>

