      <bridgehead renderas="sect4">Pyproject-Metadata Dependencies</bridgehead>

      <bridgehead renderas="sect5">Optional (for testing)</bridgehead>
      <para role="optional">
        <xref linkend="pytest"/> and
        <ulink url="https://pypi.org/project/exceptiongroup/">exceptiongroup</ulink>
      </para>

    </sect3>

    <sect3 role="installation">
      <title>Installation of Pyproject-Metadata</title>

    <para>Build the module: </para>

&build-wheel;

    <para>
      Now, as the <systemitem class="username">root</systemitem> user:
    </para>

<screen role="root"><userinput>&install-wheel; pyproject-metadata</userinput></screen>

    <!-- "pytest-cov[toml]" is referred but it seems not really used -->
    <para>
      To test the installation, make sure <xref linkend='pytest'/> is
      installed and run:
    </para>

<screen remap="test"><userinput>python3 -m venv --system-site-packages testenv &amp;&amp;
testenv/bin/pip3 install exceptiongroup        &amp;&amp;
testenv/bin/python3 -m pytest</userinput></screen>

    </sect3>

