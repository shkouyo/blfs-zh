<sect1 id="simdutf" xreflabel="simdutf-&simdutf-version;">
  <?dbhtml filename="simdutf.html"?>

  <title>simdutf-&simdutf-version;</title>

  <indexterm zone="simdutf">
    <primary sortas="a-simdutf">simdutf</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to simdutf</title>

    <para>
      The <application>simdutf</application> package contains a library used
      for processing Unicode characters with SIMD optimizations. This includes
      the SSE2 and AVX2 instruction sets and more.
    </para>

    &lfs130_checked;

    <bridgehead renderas="sect3">Package Information</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          下载地址（HTTP）：<ulink url="&simdutf-download-http;"/>
        </para>
      </listitem>
      <listitem>
        <para>
          MD5 校验和：&simdutf-md5sum;
        </para>
      </listitem>
      <listitem>
        <para>
          大小：&simdutf-size;
        </para>
      </listitem>
      <listitem>
        <para>
          预计所需磁盘空间：&simdutf-buildsize;
        </para>
      </listitem>
      <listitem>
        <para>
          预计构建时间：&simdutf-time;
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">simdutf Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <xref linkend="cmake"/>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of simdutf</title>

    <para>
      Install <application>simdutf</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr  \
      -D CMAKE_BUILD_TYPE=Release   \
      -D BUILD_SHARED_LIBS=ON       \
      -G Ninja ..                   &amp;&amp;
ninja</userinput></screen>

    <para>
      To test the results, issue: <command>ninja test</command>.
    </para>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install</userinput></screen>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Libraries</segtitle>
      <segtitle>Installed Directories</segtitle>

      <seglistitem>
        <seg>
          fastbase64 and
          sutf
        </seg>
        <seg>
          libsimdutf.so
        </seg>
        <seg>
          /usr/include/simdutf and
          /usr/lib/cmake/simdutf
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

      <varlistentry id="fastbase64">
        <term><command>fastbase64</command></term>
        <listitem>
          <para>
            encodes and decodes base64 with optimizations
          </para>
          <indexterm zone="simdutf fastbase64">
            <primary sortas="b-fastbase64">fastbase64</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="sutf">
        <term><command>sutf</command></term>
        <listitem>
          <para>
            converts the encoding of an input file from one encoding to
            another using the simdutf library
          </para>
          <indexterm zone="simdutf sutf">
            <primary sortas="b-sutf">sutf</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="libsimdutf">
        <term><filename class="libraryfile">libsimdutf.so</filename></term>
        <listitem>
          <para>
            contains functions that process Unicode characters with SIMD
            optimizations
          </para>
          <indexterm zone="simdutf libsimdutf">
            <primary sortas="c-libsimdutf">libsimdutf.so</primary>
          </indexterm>
        </listitem>
      </varlistentry>
    </variablelist>
  </sect2>
